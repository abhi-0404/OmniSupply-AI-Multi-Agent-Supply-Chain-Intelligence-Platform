# ============================================================
# OmniSupply — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Google Gemini API ────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# ── Model Routing ────────────────────────────────────────────
# Supervisor uses a more capable model for planning & report generation.
# Workers use a lighter model with a higher free-tier quota.
#
# Free-tier limits (as of 2025):
#   gemini-2.5-flash      →   20 req/day  (supervisor — quality)
#   gemini-2.5-flash-lite → 1500 req/day  (workers   — throughput)
#   gemini-2.0-flash-lite → 1500 req/day  (alternative worker model)
#
GEMINI_SUPERVISOR_MODEL=gemini-2.5-flash
GEMINI_WORKER_MODEL=gemini-2.5-flash-lite

# Legacy single-model var — used as fallback if the split vars above are absent
GEMINI_MODEL=gemini-2.5-flash-lite

# Embedding model for ChromaDB semantic search
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Rate Limiting ────────────────────────────────────────────
# Delay in milliseconds between sequential agent calls in the supervisor.
# Prevents bursting the per-minute quota. Increase if you still hit 429s.
AGENT_CALL_DELAY_MS=2000

# ── PostgreSQL ───────────────────────────────────────────────
# Docker quickstart:
#   docker run -d --name omnisupply-db \
#     -e POSTGRES_USER=omnisupply \
#     -e POSTGRES_PASSWORD=omnisupply123 \
#     -e POSTGRES_DB=omnisupply \
#     -p 5432:5432 postgres:15
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=omnisupply
POSTGRES_PASSWORD=omnisupply123
POSTGRES_DB=omnisupply

# ── Opik Observability (optional) ───────────────────────────
# Sign up at https://www.comet.com/signup to enable LLM tracing.
# Leave blank to disable (no traces will be sent).
OPIK_API_KEY=
OPIK_PROJECT_NAME=omnisupply

# ── Data ─────────────────────────────────────────────────────
DATA_DIR=data
