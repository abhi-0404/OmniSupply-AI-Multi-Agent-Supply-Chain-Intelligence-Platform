# ============================================================
# OmniSupply — .gitignore
# ============================================================

# ── Secrets & Environment ────────────────────────────────────
.env
.envrc
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.pyd
*.pyo

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.pixi/
__pypackages__/

# ── Distribution / Packaging ─────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# ── Data Files ───────────────────────────────────────────────
data/*.csv
data/*.xlsx
data/*.xls
data/*.json
data/*.parquet
data/chroma/
!data/README.md

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
pip-log.txt
pip-delete-this-directory.txt

