.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Type Checkers ────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Linters / Formatters ─────────────────────────────────────
.ruff_cache/

# ── Package Managers ─────────────────────────────────────────
.pdm-python
.pdm-build/
.pypirc

# ── Celery ───────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Docs ─────────────────────────────────────────────────────
